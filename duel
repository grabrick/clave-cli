#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  if [[ "$SOURCE" != /* ]]; then
    SOURCE="$SOURCE_DIR/$SOURCE"
  fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
LAUNCH_CWD="$(pwd -P)"
RELEASE_BIN="$SCRIPT_DIR/target/release/ai-orchestrator"
DEBUG_BIN="$SCRIPT_DIR/target/debug/ai-orchestrator"
ENGINE="$SCRIPT_DIR/spec-duel"

export DUEL_ENGINE="${DUEL_ENGINE:-$ENGINE}"
export DUEL_LAUNCH_CWD="${DUEL_LAUNCH_CWD:-$LAUNCH_CWD}"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  printf '%s\n' 'duel'
  printf '\n'
  printf '%s\n' 'Usage:'
  printf '%s\n' '  duel                         Open the Rust TUI'
  printf '%s\n' '  duel --codex-only "<task>"   Run one task through the engine'
  printf '%s\n' '  duel --help                  Show this help'
  printf '\n'
  printf '%s\n' 'Build the TUI:'
  printf '  cd "%s"\n' "$SCRIPT_DIR"
  printf '%s\n' '  cargo build --release'
  exit 0
fi

if [[ -x "$RELEASE_BIN" ]]; then
  cd "$SCRIPT_DIR"
  exec "$RELEASE_BIN" "$@"
fi

if [[ -x "$DEBUG_BIN" ]]; then
  cd "$SCRIPT_DIR"
  exec "$DEBUG_BIN" "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  cd "$SCRIPT_DIR"
  exec cargo run --quiet -- "$@"
fi

if [[ $# -gt 0 && -x "$ENGINE" ]]; then
  echo "duel: Rust TUI is not built and cargo is not installed; running direct engine fallback." >&2
  cd "$SCRIPT_DIR"
  exec "$ENGINE" "$@"
fi

{
  printf '%s\n' 'duel: Rust TUI is not available yet.'
  printf '\n'
  printf '%s\n' 'This launcher no longer opens the old shell pseudo-TUI because it breaks on'
  printf '%s\n' 'resize and cannot provide real slash-command completion.'
  printf '\n'
  printf '%s\n' 'Install Rust/Cargo, then run:'
  printf '\n'
  printf '  cd "%s"\n' "$SCRIPT_DIR"
  printf '%s\n' '  cargo build --release'
  printf '%s\n' '  duel'
  printf '\n'
  printf '%s\n' 'Direct task fallback still works without the TUI:'
  printf '\n'
  printf '%s\n' '  duel --codex-only "Plan an affiliate program"'
} >&2

exit 1
